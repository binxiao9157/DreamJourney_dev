<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB" version="3.0" toolsVersion="22154" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES" launchScreen="YES" initialViewController="01J-lp-oVM">
    <device id="retina6_12" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="22131"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <scenes>
        <scene sceneID="EHf-IW-A2E">
            <objects>
                <viewController id="01J-lp-oVM" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="Ze5-6b-2t3">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <!-- 底部暖色叠加层，模拟从底部向上渐暖 -->
                            <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="bg-overlay">
                                <color key="backgroundColor" red="0.92157" green="0.86275" blue="0.78431" alpha="0.5" colorSpace="custom" customColorSpace="sRGB"/>
                            </view>
                            <!-- 橙色装饰圆环，居中偏上（用 layer.cornerRadius 原生属性） -->
                            <view contentMode="scaleToFill" layer.cornerRadius="160" translatesAutoresizingMaskIntoConstraints="NO" id="deco-ring">
                                <color key="backgroundColor" red="0.96078" green="0.51765" blue="0.12157" alpha="0.18" colorSpace="custom" customColorSpace="sRGB"/>
                            </view>
                            <!-- "寻梦环游" 主标题 -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left"
                                   horizontalHuggingPriority="251" verticalHuggingPriority="251"
                                   text="寻梦环游" textAlignment="center"
                                   lineBreakMode="middleTruncation" baselineAdjustment="alignBaselines"
                                   adjustsFontSizeToFit="NO"
                                   translatesAutoresizingMaskIntoConstraints="NO" id="lbl-title">
                                <fontDescription key="fontDescription" name="PingFangSC-Semibold" family="PingFang SC" pointSize="72"/>
                                <color key="textColor" red="0.23922" green="0.16863" blue="0.12157" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <!-- 橙色短分隔线 -->
                            <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="deco-divider">
                                <color key="backgroundColor" red="0.96078" green="0.51765" blue="0.12157" alpha="0.7" colorSpace="custom" customColorSpace="sRGB"/>
                            </view>
                            <!-- 副标题 -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left"
                                   horizontalHuggingPriority="251" verticalHuggingPriority="251"
                                   text="记录珍贵回忆，留住美好时光" textAlignment="center"
                                   lineBreakMode="middleTruncation" baselineAdjustment="alignBaselines"
                                   adjustsFontSizeToFit="NO"
                                   translatesAutoresizingMaskIntoConstraints="NO" id="lbl-subtitle">
                                <fontDescription key="fontDescription" name="PingFangSC-Light" family="PingFang SC" pointSize="17"/>
                                <color key="textColor" red="0.54510" green="0.45098" blue="0.33333" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                                <nil key="highlightedColor"/>
                            </label>
                            <!-- 底部标语 -->
                            <label opaque="NO" userInteractionEnabled="NO" contentMode="left"
                                   horizontalHuggingPriority="251" verticalHuggingPriority="251"
                                   text="银龄记忆  温暖陪伴" textAlignment="center"
                                   lineBreakMode="middleTruncation" baselineAdjustment="alignBaselines"
                                   adjustsFontSizeToFit="NO"
                                   translatesAutoresizingMaskIntoConstraints="NO" id="lbl-tagline">
                                <fontDescription key="fontDescription" name="PingFangSC-Light" family="PingFang SC" pointSize="13"/>
                                <color key="textColor" red="0.54510" green="0.45098" blue="0.33333" alpha="0.55" colorSpace="custom" customColorSpace="sRGB"/>
                                <nil key="highlightedColor"/>
                            </label>
                        </subviews>
                        <viewLayoutGuide key="safeArea" id="6Tk-OE-BBY"/>
                        <!-- 主背景：米白 #FAF7F2 -->
                        <color key="backgroundColor" red="0.97647" green="0.96863" blue="0.94902" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                        <constraints>
                            <!-- overlay：铺满下半屏 -->
                            <constraint firstItem="bg-overlay" firstAttribute="bottom" secondItem="Ze5-6b-2t3" secondAttribute="bottom" id="c-ov-b"/>
                            <constraint firstItem="bg-overlay" firstAttribute="leading" secondItem="Ze5-6b-2t3" secondAttribute="leading" id="c-ov-l"/>
                            <constraint firstItem="bg-overlay" firstAttribute="trailing" secondItem="Ze5-6b-2t3" secondAttribute="trailing" id="c-ov-r"/>
                            <constraint firstItem="bg-overlay" firstAttribute="height" secondItem="Ze5-6b-2t3" secondAttribute="height" multiplier="0.5" id="c-ov-h"/>
                            <!-- 装饰圆环：320×320，垂直居中偏上 40pt -->
                            <constraint firstItem="deco-ring" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="c-ring-cx"/>
                            <constraint firstItem="deco-ring" firstAttribute="centerY" secondItem="Ze5-6b-2t3" secondAttribute="centerY" constant="-40" id="c-ring-cy"/>
                            <constraint firstItem="deco-ring" firstAttribute="width" secondItem="Ze5-6b-2t3" secondAttribute="width" multiplier="0" constant="320" id="c-ring-w"/>
                            <constraint firstItem="deco-ring" firstAttribute="height" secondItem="deco-ring" secondAttribute="width" id="c-ring-sq"/>
                            <!-- 主标题：水平居中，垂直居中偏上 20pt -->
                            <constraint firstItem="lbl-title" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="c-t-cx"/>
                            <constraint firstItem="lbl-title" firstAttribute="centerY" secondItem="Ze5-6b-2t3" secondAttribute="centerY" constant="-20" id="c-t-cy"/>
                            <!-- 分隔线：宽 56pt，高 1.5pt，在标题下方 14pt -->
                            <constraint firstItem="deco-divider" firstAttribute="top" secondItem="lbl-title" secondAttribute="bottom" constant="14" id="c-div-t"/>
                            <constraint firstItem="deco-divider" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="c-div-cx"/>
                            <constraint firstItem="deco-divider" firstAttribute="width" secondItem="Ze5-6b-2t3" secondAttribute="width" multiplier="0" constant="56" id="c-div-w"/>
                            <constraint firstItem="deco-divider" firstAttribute="height" secondItem="Ze5-6b-2t3" secondAttribute="height" multiplier="0" constant="1.5" id="c-div-h"/>
                            <!-- 副标题：在分隔线下方 12pt -->
                            <constraint firstItem="lbl-subtitle" firstAttribute="top" secondItem="deco-divider" secondAttribute="bottom" constant="12" id="c-sub-t"/>
                            <constraint firstItem="lbl-subtitle" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="c-sub-cx"/>
                            <!-- 底部标语：距安全区底部 32pt -->
                            <constraint firstItem="lbl-tagline" firstAttribute="bottom" secondItem="6Tk-OE-BBY" secondAttribute="bottom" constant="-32" id="c-tag-b"/>
                            <constraint firstItem="lbl-tagline" firstAttribute="centerX" secondItem="Ze5-6b-2t3" secondAttribute="centerX" id="c-tag-cx"/>
                        </constraints>
                    </view>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="iYj-Kq-Ea1" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="53" y="375"/>
        </scene>
    </scenes>
</document>
